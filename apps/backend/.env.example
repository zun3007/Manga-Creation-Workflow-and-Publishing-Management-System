# ── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3308
DB_USER=root
DB_PASSWORD=manga_root
DB_NAME=manga_creation_workflow_and_publishing_management_system

# ── Server ───────────────────────────────────────────────
PORT=3000
CLIENT_URL=http://localhost:5173
# In production the app refuses to boot while the dev secrets below are still
# in place (see apps/backend/src/main.ts → assertProductionSecrets).
# NODE_ENV=production

# ── Auth / JWT ───────────────────────────────────────────
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES=7d
# Email OTP 2FA is ON by default; set to false to bypass it (local only).
AUTH_2FA_ENABLED=true
OTP_TTL_MINUTES=10
TRUSTED_BROWSER_TTL_DAYS=30
PASSWORD_RESET_TTL_MINUTES=15
# Echo the OTP in the API response for local dev when SMTP isn't configured.
OTP_DEV_ECHO=false

# ── Google OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID=changeme
GOOGLE_CLIENT_SECRET=changeme
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ── Object storage (SeaweedFS, S3-compatible API) ────────
S3_ENDPOINT=http://localhost:8333
S3_REGION=us-east-1
S3_BUCKET=manga-uploads
S3_ACCESS_KEY=manga
S3_SECRET_KEY=manga-s3-dev-secret

# ── Email (SMTP, for OTP delivery) ───────────────────────
# Leave SMTP_* blank in local dev to fall back to OTP_DEV_ECHO instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@inkframe.studio

# ── Demo seeding (LOCAL DEV ONLY) ────────────────────────
# On boot, non-privileged demo accounts are (re)synced to DEMO_USER_PASSWORD.
# This is skipped automatically in production; set SEED_DEMO_USERS=false to
# disable it in any environment. The ADMIN account is never touched.
SEED_DEMO_USERS=true
DEMO_USER_EMAIL=dungminer69@gmail.com
DEMO_USER_PASSWORD=Dung123456@

# ── Testing / load runs ──────────────────────────────────
# Only for burst e2e/load runs (never set in production).
# DISABLE_THROTTLE=true
