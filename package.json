{
  "name": "manga-workflow",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "build:packages": "pnpm -F @manga/shared build && pnpm -F @manga/canvas-wasm build",
    "build:shared": "pnpm build:packages",
    "dev:web": "pnpm build:packages && pnpm -F web dev",
    "dev:api": "pnpm build:packages && pnpm -F api start:dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "db:up": "docker compose -f db/docker-compose.yml up -d",
    "db:down": "docker compose -f db/docker-compose.yml down"
  }
}
